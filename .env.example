# Provider: "openrouter" or "openai" (default: openrouter)
PROVIDER=openrouter

# OpenRouter credentials (required if PROVIDER=openrouter)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# OpenAI credentials (required if PROVIDER=openai)
OPENAI_API_KEY=your-openai-api-key-here

# Langfuse credentials (required)
LANGFUSE_PUBLIC_KEY=pk-your-public-key-here
LANGFUSE_SECRET_KEY=sk-your-secret-key-here
LANGFUSE_HOST=https://challenges.reply.com/langfuse

# Team name for session IDs
TEAM_NAME=your-team-name
